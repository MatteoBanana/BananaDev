<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{% if page.title %}{{ page.title }} — {% endif %}Matteo Rubert</title>
<meta name="description" content="{{ page.summary|striptags|slice(0,160) }}">

<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:ital,wght@0,400;0,700;0,900;1,900&family=Barlow:wght@400;700&display=swap" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/@emailjs/browser@4/dist/email.min.js"></script>

{% set theme_config = config.themes.rubert %}

<style>
:root {
  --blue:   #1B2EE6;
  --yellow: #F5C800;
  --white:  #F5F2EB;
  --black:  #0D0D0D;
  --red:    #E63022;
  --panel:  400px;
}
*, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: var(--white); color: var(--black);
  font-family: 'Barlow', sans-serif;
  font-size: 13px; line-height: 1.4;
  overflow-x: hidden; cursor: none;
}

/* CURSOR */
#cur {
  position: fixed; z-index: 9999; pointer-events: none;
  width: 14px; height: 14px; background: var(--blue);
  mix-blend-mode: multiply; transform: translate(-50%,-50%);
  transition: width .2s, height .2s, background .2s, border-radius .2s;
}
body.cur-hover #cur { width: 56px; height: 56px; background: var(--yellow); border-radius: 50%; }
#cur-trail {
  position: fixed; z-index: 9998; pointer-events: none;
  width: 40px; height: 40px; border: 2px solid var(--blue);
  transform: translate(-50%,-50%);
  transition: width .4s cubic-bezier(.16,1,.3,1), height .4s cubic-bezier(.16,1,.3,1), opacity .3s;
  opacity: .25;
}
body.cur-hover #cur-trail { width: 80px; height: 80px; opacity: .5; }

/* FLOATING PREVIEW */
#img-preview {
  position: fixed; z-index: 500; pointer-events: none;
  width: 280px; height: 190px; object-fit: cover; opacity: 0;
  transform: translate(-50%,-50%) scale(.82) rotate(-4deg);
  transition: opacity .28s, transform .32s cubic-bezier(.16,1,.3,1);
  box-shadow: 8px 8px 0 var(--blue); outline: 3px solid var(--black);
}
#img-preview.show { opacity: 1; transform: translate(-50%,-50%) scale(1) rotate(0deg); }

/* NAV */
nav {
  position: fixed; top: 0; left: 0; right: 0; z-index: 200;
  display: flex; justify-content: space-between; align-items: stretch;
  background: var(--blue); height: 52px;
}
.nav-logo {
  display: flex; align-items: center; padding: 0 28px;
  font-family: 'Barlow Condensed', sans-serif;
  font-size: 22px; font-weight: 900; letter-spacing: .04em;
  color: var(--white); text-transform: uppercase; text-decoration: none;
  border-right: 2px solid rgba(255,255,255,.15);
}
.nav-right { display: flex; align-items: stretch; }
.nav-link {
  display: flex; align-items: center; padding: 0 24px;
  font-size: 11px; letter-spacing: .18em; text-transform: uppercase;
  color: rgba(245,242,235,.55); text-decoration: none;
  border-right: 2px solid rgba(255,255,255,.1);
  transition: color .15s, background .15s;
}
.nav-link:hover { color: var(--white); background: rgba(255,255,255,.08); }
#contact-btn {
  display: flex; align-items: center; gap: 10px; padding: 0 28px;
  background: var(--yellow); color: var(--black); border: none;
  font-family: 'Barlow', sans-serif;
  font-size: 11px; font-weight: 700; letter-spacing: .18em; text-transform: uppercase;
  cursor: none; transition: background .15s;
}
#contact-btn:hover { background: var(--white); }

/* CONTACT PANEL */
#ct-bg { position: fixed; inset: 0; z-index: 300; background: transparent; pointer-events: none; transition: background .4s; }
#ct-bg.open { background: rgba(13,13,13,.7); pointer-events: all; }
#ct-panel {
  position: fixed; top: 0; right: 0; bottom: 0; z-index: 301;
  width: var(--panel); background: var(--black); color: var(--white);
  display: flex; flex-direction: column; overflow-y: auto;
  transform: translateX(100%); transition: transform .55s cubic-bezier(.16,1,.3,1);
}
#ct-panel.open { transform: translateX(0); }
.ct-panel-top { background: var(--blue); padding: 40px 40px 36px; position: relative; overflow: hidden; flex-shrink: 0; }
.ct-panel-bg-letter {
  position: absolute; right: -20px; bottom: -30px;
  font-family: 'Barlow Condensed', sans-serif; font-size: 160px; font-weight: 900; line-height: 1;
  color: transparent; -webkit-text-stroke: 2px rgba(245,242,235,.1);
  pointer-events: none; user-select: none;
}
.ct-x {
  display: flex; align-items: center; gap: 8px;
  background: none; border: 2px solid rgba(245,242,235,.25); color: var(--white);
  font-family: 'Barlow', sans-serif; font-size: 10px; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  padding: 7px 14px; cursor: none; margin-bottom: 36px; align-self: flex-start;
  transition: border-color .2s, background .2s, color .2s;
}
.ct-x:hover { border-color: var(--yellow); background: var(--yellow); color: var(--black); }
.ct-x svg { width: 12px; }
.ct-h { font-family: 'Barlow Condensed', sans-serif; font-size: 52px; font-weight: 900; line-height: .85; text-transform: uppercase; color: var(--white); position: relative; z-index: 1; }
.ct-h em { font-style: italic; color: var(--yellow); display: block; }
.ct-yellow-bar { height: 6px; background: var(--yellow); flex-shrink: 0; }
.ct-body { padding: 36px 40px; flex: 1; }
.ct-intro { font-size: 13px; line-height: 1.8; color: rgba(245,242,235,.5); margin-bottom: 36px; padding-bottom: 32px; border-bottom: 1px solid rgba(245,242,235,.1); }
.ct-item { margin-bottom: 28px; }
.ct-lbl { font-size: 9px; letter-spacing: .24em; text-transform: uppercase; color: rgba(245,242,235,.28); margin-bottom: 6px; }
.ct-val { font-size: 14px; }
.ct-val a { color: var(--white); text-decoration: none; border-bottom: 1px solid rgba(245,242,235,.2); transition: color .2s, border-color .2s; }
.ct-val a:hover { color: var(--yellow); border-color: var(--yellow); }
.ct-form { margin-top: 36px; padding-top: 32px; border-top: 1px solid rgba(245,242,235,.1); }
.ct-form-label { font-family: 'Barlow Condensed', sans-serif; font-size: 18px; font-weight: 700; text-transform: uppercase; letter-spacing: .04em; color: rgba(245,242,235,.4); margin-bottom: 24px; }
.ct-field { margin-bottom: 18px; }
.ct-field label { display: block; font-size: 9px; letter-spacing: .24em; text-transform: uppercase; color: rgba(245,242,235,.28); margin-bottom: 7px; }
.ct-field input,
.ct-field textarea {
  display: block; width: 100%; background: rgba(245,242,235,.05);
  border: none; border-bottom: 2px solid rgba(245,242,235,.15);
  color: var(--white); font-family: 'Barlow', sans-serif;
  font-size: 13px; line-height: 1.5; padding: 10px 0;
  outline: none; cursor: none; border-radius: 0; -webkit-appearance: none;
  transition: border-color .2s, background .2s;
}
.ct-field input:focus,
.ct-field textarea:focus { border-bottom-color: var(--yellow); background: rgba(245,242,235,.08); }
.ct-field input::placeholder,
.ct-field textarea::placeholder { color: rgba(245,242,235,.18); }
.ct-field textarea { resize: none; height: 84px; }
.ct-submit {
  display: flex; align-items: center; justify-content: space-between;
  width: 100%; margin-top: 24px;
  background: var(--blue); color: var(--white); border: none;
  font-family: 'Barlow', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: .18em; text-transform: uppercase;
  padding: 16px 20px; cursor: none; transition: background .2s;
}
.ct-submit:hover { background: var(--yellow); color: var(--black); }
.ct-submit:disabled { opacity: .4; pointer-events: none; }
.ct-submit svg { width: 16px; }
.ct-feedback { margin-top: 12px; font-size: 11px; letter-spacing: .08em; min-height: 18px; }
.ct-feedback.ok  { color: #6ECA82; }
.ct-feedback.err { color: #E07070; }
.ct-foot { padding: 24px 40px; border-top: 1px solid rgba(245,242,235,.08); font-size: 9px; letter-spacing: .2em; text-transform: uppercase; color: rgba(245,242,235,.15); }

/* ANIMATIONS */
@keyframes slideUp { from { opacity:0; transform:translateY(40px); } to { opacity:1; transform:translateY(0); } }
.anim { animation: slideUp 1s cubic-bezier(.16,1,.3,1) both; }
.a1 { animation-delay: .05s; } .a2 { animation-delay: .15s; } .a3 { animation-delay: .25s; }
</style>
</head>
<body>

<div id="cur"></div>
<div id="cur-trail"></div>
<img id="img-preview" src="" alt="">

<nav>
  <a href="{{ base_url_absolute }}" class="nav-logo">Matteo Rubert</a>
  <div class="nav-right">
    <a href="{{ base_url_absolute }}" class="nav-link">Index</a>
    <button id="contact-btn" onclick="openContact()">
      Contatti
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14">
        <path stroke-linecap="round" stroke-linejoin="round" d="M21.75 6.75v10.5a2.25 2.25 0 01-2.25 2.25h-15a2.25 2.25 0 01-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0019.5 4.5h-15a2.25 2.25 0 00-2.25 2.25m19.5 0v.243a2.25 2.25 0 01-1.07 1.916l-7.5 4.615a2.25 2.25 0 01-2.36 0L3.32 8.91a2.25 2.25 0 01-1.07-1.916V6.75"/>
      </svg>
    </button>
  </div>
</nav>

{% block content %}{% endblock %}

<!-- CONTACT PANEL -->
<div id="ct-bg" onclick="closeContact()"></div>
<div id="ct-panel">
  <div class="ct-panel-top">
    <div class="ct-panel-bg-letter">C</div>
    <button class="ct-x" onclick="closeContact()">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="12"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg>
      Chiudi
    </button>
    <div class="ct-h">Parliamo<em>insieme.</em></div>
  </div>
  <div class="ct-yellow-bar"></div>
  <div class="ct-body">
    <p class="ct-intro">Lavoro con brand, studi e professionisti che credono nel potere di un progetto fatto bene. Se hai qualcosa in mente, scrivi — rispondo sempre.</p>
    <div class="ct-item">
      <div class="ct-lbl">Email</div>
      <div class="ct-val"><a href="mailto:{{ theme_config.contact_email }}">{{ theme_config.contact_email }}</a></div>
    </div>
    <div class="ct-item">
      <div class="ct-lbl">Telefono</div>
      <div class="ct-val"><a href="tel:{{ theme_config.contact_phone|replace({' ':''}) }}">{{ theme_config.contact_phone }}</a></div>
    </div>
    <div class="ct-item">
      <div class="ct-lbl">Studio</div>
      <div class="ct-val">{{ theme_config.contact_studio }}</div>
    </div>
    <div class="ct-item">
      <div class="ct-lbl">Online</div>
      <div class="ct-val">
        <a href="{{ theme_config.instagram_url }}" target="_blank">Instagram</a> ·
        <a href="{{ theme_config.linkedin_url }}" target="_blank">LinkedIn</a> ·
        <a href="{{ theme_config.bananastudio_url }}" target="_blank">BananaStudio.it</a>
      </div>
    </div>
    <div class="ct-form">
      <div class="ct-form-label">Scrivimi direttamente</div>
      <div class="ct-field"><label for="ct-name">Nome</label><input type="text" id="ct-name" placeholder="Il tuo nome" autocomplete="name"></div>
      <div class="ct-field"><label for="ct-email">Email</label><input type="email" id="ct-email" placeholder="tua@email.com" autocomplete="email"></div>
      <div class="ct-field"><label for="ct-subject">Oggetto</label><input type="text" id="ct-subject" placeholder="Di cosa hai bisogno?"></div>
      <div class="ct-field"><label for="ct-msg">Messaggio</label><textarea id="ct-msg" placeholder="Raccontami il progetto…"></textarea></div>
      <button class="ct-submit" id="ct-submit" onclick="sendMail()">
        <span id="ct-btn-lbl">Invia messaggio</span>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
      </button>
      <div class="ct-feedback" id="ct-feedback"></div>
    </div>
  </div>
  <div class="ct-foot">Matteo Rubert © {{ "now"|date("Y") }}</div>
</div>

<script>
const EJS_PUBLIC_KEY  = '{{ theme_config.emailjs_public_key }}';
const EJS_SERVICE_ID  = '{{ theme_config.emailjs_service_id }}';
const EJS_TEMPLATE_ID = '{{ theme_config.emailjs_template_id }}';
emailjs.init({ publicKey: EJS_PUBLIC_KEY });

/* CURSOR */
const cur   = document.getElementById('cur');
const trail = document.getElementById('cur-trail');
let mx=0, my=0, tx=0, ty=0;
document.addEventListener('mousemove', e => { mx=e.clientX; my=e.clientY; });
(function tick() {
  tx+=(mx-tx)*.12; ty+=(my-ty)*.12;
  cur.style.left=mx+'px';   cur.style.top=my+'px';
  trail.style.left=tx+'px'; trail.style.top=ty+'px';
  requestAnimationFrame(tick);
})();
document.querySelectorAll('a,button,.proj-row').forEach(el => {
  el.addEventListener('mouseenter', () => document.body.classList.add('cur-hover'));
  el.addEventListener('mouseleave', () => document.body.classList.remove('cur-hover'));
});

/* FLOATING PREVIEW */
const imgPrev = document.getElementById('img-preview');
let px=window.innerWidth/2, py=window.innerHeight/2, ptx=px, pty=py, prevOn=false;
(function ap() {
  px+=(ptx-px)*.09; py+=(pty-py)*.09;
  imgPrev.style.left=px+'px'; imgPrev.style.top=py+'px';
  requestAnimationFrame(ap);
})();
document.querySelectorAll('.proj-row[data-img]').forEach(row => {
  row.addEventListener('mouseenter', () => { imgPrev.src=row.dataset.img; imgPrev.classList.add('show'); prevOn=true; });
  row.addEventListener('mouseleave', () => { imgPrev.classList.remove('show'); prevOn=false; });
});
document.addEventListener('mousemove', e => { if(!prevOn) return; ptx=e.clientX+72; pty=e.clientY-28; });

/* CONTACT */
function openContact() {
  document.getElementById('ct-bg').classList.add('open');
  document.getElementById('ct-panel').classList.add('open');
  document.body.style.overflow='hidden';
}
function closeContact() {
  document.getElementById('ct-bg').classList.remove('open');
  document.getElementById('ct-panel').classList.remove('open');
  document.body.style.overflow='';
}
document.addEventListener('keydown', e => { if(e.key==='Escape') closeContact(); });

/* EMAILJS */
async function sendMail() {
  const name    = document.getElementById('ct-name').value.trim();
  const email   = document.getElementById('ct-email').value.trim();
  const subject = document.getElementById('ct-subject').value.trim();
  const message = document.getElementById('ct-msg').value.trim();
  const fb=document.getElementById('ct-feedback');
  const btn=document.getElementById('ct-submit');
  const lbl=document.getElementById('ct-btn-lbl');
  fb.className='ct-feedback'; fb.textContent='';
  if(!name)    { setFb('err','Inserisci il tuo nome.'); return; }
  if(!email||!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) { setFb('err','Email non valida.'); return; }
  if(!message) { setFb('err','Scrivi un messaggio.'); return; }
  btn.disabled=true; lbl.textContent='Invio in corso…';
  try {
    await emailjs.send(EJS_SERVICE_ID, EJS_TEMPLATE_ID, { from_name:name, from_email:email, subject:subject||'(nessun oggetto)', message });
    setFb('ok','✓ Messaggio inviato. Ti rispondo presto!');
    lbl.textContent='Inviato ✓';
    setTimeout(() => {
      ['ct-name','ct-email','ct-subject','ct-msg'].forEach(id => document.getElementById(id).value='');
      lbl.textContent='Invia messaggio'; btn.disabled=false; fb.textContent='';
    }, 3500);
  } catch(err) {
    setFb('err','Errore nell\'invio. Riprova o scrivimi direttamente.');
    lbl.textContent='Invia messaggio'; btn.disabled=false;
  }
}
function setFb(type,msg) {
  const fb=document.getElementById('ct-feedback');
  fb.className='ct-feedback '+type; fb.textContent=msg;
}
{% block scripts %}{% endblock %}
</script>
</body>
</html>
