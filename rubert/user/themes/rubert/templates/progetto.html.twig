{% extends 'base.html.twig' %}

{% block content %}
<style>
#project { padding-top: 52px; }

/* BLUE HEADER BAND */
.pj-band { background: var(--blue); padding: 52px 52px 0; position: relative; overflow: hidden; }
.pj-band-bg {
  position: absolute; right: 0; bottom: -20px;
  font-family: 'Barlow Condensed', sans-serif; font-size: 240px; font-weight: 900; line-height: 1;
  color: transparent; -webkit-text-stroke: 2px rgba(245,242,235,.1);
  pointer-events: none; user-select: none;
}
.pj-back {
  display: inline-flex; align-items: center; gap: 8px;
  background: none; border: 2px solid rgba(245,242,235,.3); color: var(--white);
  font-family: 'Barlow', sans-serif; font-size: 10px; font-weight: 700;
  letter-spacing: .2em; text-transform: uppercase;
  padding: 8px 16px; cursor: none; margin-bottom: 40px; text-decoration: none;
  transition: border-color .2s, background .2s, color .2s;
}
.pj-back:hover { border-color: var(--yellow); background: var(--yellow); color: var(--black); }
.pj-back svg { width: 14px; }
.pj-title-txt {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(44px, 7vw, 96px); font-weight: 900; text-transform: uppercase;
  line-height: .88; color: var(--white); position: relative; z-index: 1; padding-bottom: 52px;
}
.pj-yellow-bar { height: 8px; background: var(--yellow); }

/* META STRIP */
.pj-meta-strip { display: grid; grid-template-columns: repeat(3,1fr); border-bottom: 2px solid var(--black); }
.pj-meta-cell { padding: 24px 52px; border-right: 2px solid var(--black); }
.pj-meta-cell:last-child { border-right: none; }
.pj-meta-label { font-size: 9px; letter-spacing: .22em; text-transform: uppercase; color: #888; margin-bottom: 6px; }
.pj-meta-val { font-family: 'Barlow Condensed', sans-serif; font-size: 20px; font-weight: 700; text-transform: uppercase; }

.pj-cover { width: 100%; height: 54vh; object-fit: cover; display: block; }

/* BODY */
.pj-body { display: grid; grid-template-columns: 1fr 1fr; border-bottom: 2px solid var(--black); }
.pj-col { padding: 56px 52px; font-size: 15px; line-height: 1.8; color: #444; }
.pj-col:first-child { border-right: 2px solid var(--black); }
.pj-col p { margin-bottom: 18px; }
.pj-col p:last-child { margin: 0; }

/* GALLERY */
.pj-gallery { display: grid; grid-template-columns: 1fr 1fr; }
.pj-gallery img { width: 100%; aspect-ratio: 4/3; object-fit: cover; display: block; outline: 1px solid var(--black); transition: filter .3s; }
.pj-gallery img:hover { filter: brightness(1.06); }

/* NAV */
.pj-nav-bar { display: flex; justify-content: space-between; align-items: stretch; border-top: 2px solid var(--black); }
.pj-nav-btn {
  display: flex; align-items: center; gap: 10px; flex: 1; padding: 22px 52px;
  background: none; border: none; cursor: none; text-decoration: none;
  font-family: 'Barlow', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase; color: #888;
  transition: color .2s, background .2s;
}
.pj-nav-btn:hover { color: var(--white); background: var(--blue); }
.pj-nav-btn.next { justify-content: flex-end; border-left: 2px solid var(--black); }
.pj-nav-btn svg { width: 18px; }
.pj-nav-count {
  display: flex; align-items: center; padding: 0 40px;
  font-family: 'Barlow Condensed', sans-serif; font-size: 32px; font-weight: 900;
  border-left: 2px solid var(--black); border-right: 2px solid var(--black); color: var(--black);
}

/* External link button */
.pj-ext-link {
  display: inline-flex; align-items: center; gap: 8px; margin-top: 24px;
  background: var(--blue); color: var(--white);
  font-family: 'Barlow', sans-serif; font-size: 11px; font-weight: 700;
  letter-spacing: .16em; text-transform: uppercase; text-decoration: none;
  padding: 12px 20px; transition: background .2s;
}
.pj-ext-link:hover { background: var(--yellow); color: var(--black); }
</style>

{# Get siblings for prev/next navigation #}
{% set siblings = page.parent.children.ofType('progetto').published %}
{% set siblings_arr = siblings|array %}
{% set current_idx = 0 %}
{% for s in siblings_arr %}
  {% if s.slug == page.slug %}{% set current_idx = loop.index0 %}{% endif %}
{% endfor %}
{% set prev_page = current_idx > 0 ? siblings_arr[current_idx - 1] : null %}
{% set next_page = current_idx < (siblings_arr|length - 1) ? siblings_arr[current_idx + 1] : null %}
{% set total = siblings_arr|length %}

<div id="project">
  <div class="pj-band">
    <div class="pj-band-bg">{{ '%02d'|format(current_idx + 1) }}</div>
    <a class="pj-back" href="{{ page.parent.url }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Tutti i progetti
    </a>
    <h1 class="pj-title-txt">{{ page.title }}</h1>
  </div>

  <div class="pj-yellow-bar"></div>

  <div class="pj-meta-strip">
    <div class="pj-meta-cell">
      <div class="pj-meta-label">Categoria</div>
      <div class="pj-meta-val">{{ header.project_tags|default('—') }}</div>
    </div>
    <div class="pj-meta-cell">
      <div class="pj-meta-label">Anno</div>
      <div class="pj-meta-val">{{ header.project_year|default('—') }}</div>
    </div>
    <div class="pj-meta-cell">
      <div class="pj-meta-label">Ruolo</div>
      <div class="pj-meta-val">{{ header.project_role|default('—') }}</div>
    </div>
  </div>

  {% if header.project_cover %}
  <img class="pj-cover"
       src="{{ base_url_absolute }}/user/pages/01.home/{{ page.folder }}/{{ header.project_cover }}"
       alt="{{ page.title }}">
  {% endif %}

  <div class="pj-body">
    <div class="pj-col">
      {{ content|raw }}
      {% if header.project_external_url %}
      <a href="{{ header.project_external_url }}" target="_blank" class="pj-ext-link">
        Visita il sito
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="14"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25"/></svg>
      </a>
      {% endif %}
    </div>
    <div class="pj-col">
      {# Gallery images #}
      {% if header.project_images %}
      <div class="pj-gallery">
        {% for img in header.project_images %}
        <img src="{{ base_url_absolute }}/user/pages/01.home/{{ page.folder }}/{{ img.src }}"
             alt="{{ page.title }} — immagine {{ loop.index }}">
        {% endfor %}
      </div>
      {% endif %}
    </div>
  </div>

  <div class="pj-nav-bar">
    {% if prev_page %}
    <a class="pj-nav-btn" href="{{ prev_page.url }}">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Precedente
    </a>
    {% else %}
    <span class="pj-nav-btn" style="opacity:.25;pointer-events:none;">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
      Precedente
    </span>
    {% endif %}

    <span class="pj-nav-count">{{ '%02d'|format(current_idx + 1) }} / {{ '%02d'|format(total) }}</span>

    {% if next_page %}
    <a class="pj-nav-btn next" href="{{ next_page.url }}">
      Successivo
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </a>
    {% else %}
    <span class="pj-nav-btn next" style="opacity:.25;pointer-events:none;">
      Successivo
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </span>
    {% endif %}
  </div>
</div>
{% endblock %}
