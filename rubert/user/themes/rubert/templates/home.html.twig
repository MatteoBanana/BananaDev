{% extends 'base.html.twig' %}

{% block content %}
<style>
/* HERO */
.hero {
  padding-top: 52px; min-height: 100vh; background: var(--blue);
  display: grid; grid-template-rows: 1fr auto; position: relative; overflow: hidden;
}
.hero-bg {
  position: absolute; inset: 0; display: flex; align-items: flex-end;
  overflow: hidden; pointer-events: none; user-select: none;
}
.hero-bg-text {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(220px, 34vw, 500px); font-weight: 900; line-height: .82;
  color: transparent; -webkit-text-stroke: 2px rgba(245,242,235,.12);
  letter-spacing: -.03em; white-space: nowrap; transform: translateX(-20px);
}
.hero-content {
  position: relative; z-index: 2; padding: 80px 52px 60px;
  display: flex; flex-direction: column; justify-content: flex-end;
}
.hero-tag {
  display: inline-flex; align-items: center; gap: 12px;
  background: var(--yellow); color: var(--black);
  font-size: 10px; font-weight: 700; letter-spacing: .22em; text-transform: uppercase;
  padding: 6px 14px; align-self: flex-start; margin-bottom: 32px;
}
.hero-name {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(88px, 14vw, 200px); font-weight: 900; line-height: .82;
  letter-spacing: -.02em; text-transform: uppercase; color: var(--white);
}
.hero-name .line-italic { font-style: italic; color: var(--yellow); display: block; }
.hero-bar { width: 100%; height: 6px; background: var(--yellow); position: relative; z-index: 2; }
.hero-footer { position: relative; z-index: 2; display: grid; grid-template-columns: repeat(3,1fr); border-top: 2px solid rgba(245,242,235,.15); }
.hf-cell { padding: 24px 52px; border-right: 2px solid rgba(245,242,235,.1); }
.hf-cell:last-child { border-right: none; }
.hf-label { font-size: 9px; letter-spacing: .24em; text-transform: uppercase; color: rgba(245,242,235,.4); margin-bottom: 6px; }
.hf-val { font-family: 'Barlow Condensed', sans-serif; font-size: 22px; font-weight: 700; text-transform: uppercase; color: var(--white); }

/* PROJECT LIST */
.list-head { padding: 72px 52px 0; display: flex; justify-content: space-between; align-items: flex-end; }
.list-heading { font-family: 'Barlow Condensed', sans-serif; font-size: clamp(48px, 7vw, 96px); font-weight: 900; text-transform: uppercase; line-height: .9; letter-spacing: -.02em; }
.list-heading em { font-style: italic; color: var(--blue); }
.list-total { font-size: 10px; letter-spacing: .2em; text-transform: uppercase; color: #888; padding-bottom: 12px; }
.proj-list { padding: 32px 0 120px; }
.proj-row {
  display: grid; grid-template-columns: 100px 1fr auto 60px;
  align-items: center; padding: 0 52px;
  border-top: 2px solid var(--black); position: relative; overflow: hidden;
  cursor: none; min-height: 88px; text-decoration: none; color: inherit;
  display: grid;
}
.proj-list .proj-row:last-child { border-bottom: 2px solid var(--black); }
.proj-row::before {
  content: ''; position: absolute; inset: 0; background: var(--blue);
  transform: translateY(100%); transition: transform .48s cubic-bezier(.76,0,.24,1); z-index: 0;
}
.proj-row:hover::before { transform: translateY(0); }
.proj-row > * { position: relative; z-index: 1; }
.pr-num {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(52px, 6vw, 80px); font-weight: 900; line-height: 1;
  color: var(--black); -webkit-text-stroke: 1px var(--black);
  transition: color .3s .04s, -webkit-text-stroke .3s .04s; padding: 16px 0;
}
.proj-row:hover .pr-num { color: rgba(245,242,235,.15); -webkit-text-stroke: 1.5px var(--yellow); }
.pr-body { padding: 0 20px; }
.pr-title {
  font-family: 'Barlow Condensed', sans-serif;
  font-size: clamp(26px, 3vw, 42px); font-weight: 900; text-transform: uppercase; line-height: 1;
  transition: color .3s .04s, letter-spacing .4s cubic-bezier(.16,1,.3,1);
}
.proj-row:hover .pr-title { color: var(--white); letter-spacing: .02em; }
.pr-tags { margin-top: 4px; font-size: 10px; letter-spacing: .16em; text-transform: uppercase; color: #888; transition: color .3s .04s; }
.proj-row:hover .pr-tags { color: rgba(245,242,235,.5); }
.pr-year { font-size: 11px; letter-spacing: .1em; color: #888; transition: color .3s .04s; text-align: right; }
.proj-row:hover .pr-year { color: rgba(245,242,235,.4); }
.pr-arrow { display: flex; align-items: center; justify-content: flex-end; opacity: 0; transform: translateX(-12px); transition: opacity .25s .06s, transform .4s cubic-bezier(.16,1,.3,1); }
.proj-row:hover .pr-arrow { opacity: 1; transform: translateX(0); }
.pr-arrow svg { width: 24px; color: var(--yellow); }
</style>

{# HERO #}
<div class="hero">
  <div class="hero-bg"><div class="hero-bg-text">MR</div></div>
  <div class="hero-content">
    <div class="hero-tag anim">★ &nbsp; {{ header.hero_tag|default('Art Director & Designer — Verona, IT') }}</div>
    <h1 class="hero-name anim a1">
      Matteo
      <span class="line-italic">Rubert.</span>
    </h1>
  </div>
  <div class="hero-bar"></div>
  <div class="hero-footer anim a2">
    <div class="hf-cell">
      <div class="hf-label">Ruolo</div>
      <div class="hf-val">{{ header.hero_role|default('Art Director & Designer') }}</div>
    </div>
    <div class="hf-cell">
      <div class="hf-label">Studio</div>
      <div class="hf-val">{{ header.hero_studio|default('BananaStudio, Verona') }}</div>
    </div>
    <div class="hf-cell">
      <div class="hf-label">Stato</div>
      <div class="hf-val">{{ header.hero_status|default('Disponibile ✦') }}</div>
    </div>
  </div>
</div>

{# PROJECT LIST — recupera le pagine figlie con template "progetto" #}
{% set projects = page.children.ofType('progetto').published %}
{% set total = projects|length %}

<div class="list-head anim a3">
  <h2 class="list-heading">Lavori<br><em>selezionati</em></h2>
  <span class="list-total">{{ '%02d'|format(total) }} progetti</span>
</div>

<div class="proj-list">
  {% for proj in projects %}
  {% set idx = loop.index %}
  <a class="proj-row"
     href="{{ proj.url }}"
     data-img="{{ base_url_absolute }}/user/pages/01.home/{{ proj.folder }}/{{ proj.header.project_cover }}">
    <span class="pr-num">{{ '%02d'|format(idx) }}</span>
    <div class="pr-body">
      <div class="pr-title">{{ proj.title }}</div>
      <div class="pr-tags">{{ proj.header.project_tags|default('') }}</div>
    </div>
    <span class="pr-year">{{ proj.header.project_year|default('') }}</span>
    <span class="pr-arrow">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/>
      </svg>
    </span>
  </a>
  {% endfor %}
</div>
{% endblock %}
